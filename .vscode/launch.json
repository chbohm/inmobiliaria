{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (QA)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "args": [
        "./src/app/main.ts"
      ],
      "env": {
        "CONFIG_TS": "config.qa.ts"
      },
      "preLaunchTask": "build shared contracts",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Frontend (Local Backend)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/apps/frontend",
      "preLaunchTask": "serve frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + Frontend)",
      "configurations": [
        "Backend (QA)",
        "Frontend (Local Backend)"
      ]
    }
  ]
}
