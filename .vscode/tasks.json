{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build shared contracts",
      "type": "shell",
      "command": "npm run build:contracts",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "serve frontend",
      "type": "shell",
      "command": "npm run start -w @inmobiliaria/frontend -- --host 0.0.0.0 --port 4200",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["build shared contracts"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Watch mode enabled|Application bundle generation complete"
        }
      }
    }
  ]
}
